DATABASE_URL=sqlite:./data/forge.db
# Production (VPS co-located Postgres):
# DATABASE_URL=postgres://forge:forge@127.0.0.1:5432/forge
BIND_ADDR=127.0.0.1:8092
SELLER_PUBLIC_BASE_URL=http://127.0.0.1:8092
FACILITATOR_BASE_URL=https://preview.ipay.sh
SOLANA_CLUSTER=devnet
# Devnet: skip vault check only for local dev (set to 1). Preview/production VPS must use 0.
# SKIP_SELLER_VAULT_CHECK=1
# Require wallet signature on POST /listings (default). Dev scripts may set SKIP_SELLER_AUTH=1.
# SKIP_SELLER_AUTH=1
# Comma-separated browser origins (defaults: localhost:5175 dev, http402.trade prod)
# CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/objects
# R2 (when STORAGE_BACKEND=r2)
# OBJECT_DELIVERY=redirect
# PRESIGN_TTL_SECS=300
# R2_ACCOUNT_ID=
# R2_BUCKET=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# Optional Phase 2
# PLATFORM_FEE_BPS=200
# ESCROW_SIZE_THRESHOLD_BYTES=10485760
# ORACLE_AUTHORITIES=pubkey1,pubkey2
# ORACLE_PROFILE_ID=x402/oracles/file-delivery/attestation/v1
