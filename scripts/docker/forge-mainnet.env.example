# Production / mainnet — copy to /etc/forge/mainnet.env
#
# Public URLs:
#   Web (Vercel):  https://http402.trade
#   API (nginx):   https://forge.http402.trade

SOLANA_CLUSTER=mainnet
BIND_ADDR=127.0.0.1:8093
SELLER_PUBLIC_BASE_URL=https://forge.http402.trade
FACILITATOR_BASE_URL=https://ipay.sh

DATABASE_URL=postgresql://postgres:CHANGE_ME@aws-0-us-west-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_SSL_ROOT_CERT=/etc/forge/ssl/supabase-prod-ca.crt

STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_BUCKET=forge-prod
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

SKIP_SELLER_VAULT_CHECK=0
CORS_ALLOWED_ORIGINS=https://http402.trade,https://www.http402.trade

PREVIEW_MEDIA_SECONDS=30
RUST_LOG=http402_forge_api=info,tower_http=warn
