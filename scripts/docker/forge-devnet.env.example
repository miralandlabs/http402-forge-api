# Preview / devnet — copy to /etc/forge/devnet.env
#
# Public URLs (preview.* pattern, same as sibling apps):
#   Web (Vercel):  https://preview.http402.trade
#   API (nginx):   https://preview.forge.http402.trade

SOLANA_CLUSTER=devnet
BIND_ADDR=127.0.0.1:8092
SELLER_PUBLIC_BASE_URL=https://preview.forge.http402.trade
FACILITATOR_BASE_URL=https://preview.ipay.sh

# Supabase (optional) — MUST end with ?sslmode=require
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
# Or keep SQLite for preview (default):
DATABASE_URL=sqlite:/app/data/forge.db

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/data/objects

# Devnet preview stack — vault required (anti-spam). Local dev only: SKIP_SELLER_VAULT_CHECK=1
SKIP_SELLER_VAULT_CHECK=0
# SKIP_SELLER_AUTH=1

CORS_ALLOWED_ORIGINS=https://preview.http402.trade,http://localhost:5175,http://127.0.0.1:5175

# R2 (production preview — optional)
# STORAGE_BACKEND=r2
# R2_ACCOUNT_ID=
# R2_BUCKET=forge-preview
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

PREVIEW_MEDIA_SECONDS=30
RUST_LOG=http402_forge_api=info,tower_http=warn
